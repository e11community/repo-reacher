{
  "name": "repo-reacher",
  "version": "1.1.1",
  "description": "Authorize git to clone private repositories across one or more orgs using a GitHub App, then rewrite git config so later steps (terraform init, etc.) authenticate transparently.",
  "private": true,
  "license": "MIT",
  "author": "e11community",
  "scripts": {
    "build": "esbuild src/action.ts --bundle --platform=node --target=node24 --format=cjs --minify --outfile=dist/action.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "commit": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@octokit/auth-app": "^7.2.1",
    "@octokit/request": "^9.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21",
    "@commitlint/config-conventional": "^21",
    "@types/node": "^24",
    "commitizen": "^4",
    "conventional-changelog": "^7",
    "conventional-changelog-conventionalcommits": "^9",
    "conventional-recommended-bump": "^11",
    "cz-conventional-changelog": "^3",
    "esbuild": "^0.28",
    "husky": "^9",
    "lint-staged": "^16",
    "prettier": "^3",
    "typescript": "^5"
  }
}
